  <AllowedDependency from="Caller" to="AllowedInheritanceDependency" allowedSites="Inheritance" />
  <AllowedDependency from="Caller" to="AllowedInterfaceImplementationDependency" allowedSites="InterfaceImplementation" />
  <AllowedDependency from="Caller" to="AllowedAttributeDependency" allowedSites="Attribute" />
  <AllowedDependency from="Caller" to="AllowedStaticMemberDependency" allowedSites="StaticMember" />

  <AllowedDependency from="Caller" to="BlockedConstructorDependency" blockedSites="Constructor" />
