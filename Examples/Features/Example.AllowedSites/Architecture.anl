  <Layer name="BlockedAttributeDependency"><Class typeName="BlockedAttributeType" /></Layer>
  <Layer name="BlockedStaticMemberDependency"><Class typeName="BlockedStaticMemberType" /></Layer>

  <AllowedDependency from="Caller" to="AllowedConstructorDependency" allowedSites="Constructor" />
