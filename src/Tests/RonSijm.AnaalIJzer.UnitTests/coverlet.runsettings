<?xml version="1.0" encoding="utf-8" ?>
<!--
  The analyzer is referenced as a normal project reference, so coverlet
  instruments the production assembly. IncludeTestAssembly=true also instruments
  the small test-only helper types that participate in analyzer/code-fix tests.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <IncludeTestAssembly>true</IncludeTestAssembly>
          <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
